# Bruno API Testing Environment Variables
# Copy this file to .env.bruno and fill in your actual values
# DO NOT commit .env.bruno to git!

# Supabase Configuration (required for JWT token generation)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Note: These should match your server's environment variables
# The JWT secret is used to generate test tokens for API authentication
