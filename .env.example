# Database
DATABASE_URL=postgres://postgres:password@localhost:54322/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (for Asynq)
REDIS_URL=localhost:6379

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Groq
GROQ_API_KEY=gsk_your-groq-api-key
#HJ|# Cerebras
#ZK|CEREBRAS_API_KEY=your-cerebras-api-key

# Apify (for TikTok scraping)
APIFY_API_KEY=your-apify-api-key

# Proxy (for Instagram scraping)
PROXY_SERVER_URL=https://your-proxy-server.com
PROXY_API_KEY=your-proxy-api-key

# YouTube (for YouTube video scraping)
YOUTUBE_API_KEY=your-youtube-api-key

# Observability
ENV=development
SERVICE_NAME=socialchef-remy
SERVICE_VERSION=1.0.0

# Server
PORT=8080
